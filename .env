# Environment Variables for Real Lead Scraper

# LinkedIn scraping configuration
LINKEDIN_BASE_URL=https://www.linkedin.com
LINKEDIN_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
LINKEDIN_DELAY=2000
LINKEDIN_MAX_PAGES=5
LINKEDIN_MAX_RETRIES=3

# Google Maps scraping configuration
GOOGLE_MAPS_BASE_URL=https://www.google.com/maps
GOOGLE_MAPS_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
GOOGLE_MAPS_DELAY=1500
GOOGLE_MAPS_MAX_RESULTS=50
GOOGLE_MAPS_MAX_RETRIES=3

# Glassdoor scraping configuration
GLASSDOOR_BASE_URL=https://www.glassdoor.com
GLASSDOOR_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
GLASSDOOR_DELAY=3000
GLASSDOOR_MAX_PAGES=3
GLASSDOOR_MAX_RETRIES=3

# General scraping configuration
GENERAL_DELAY=1000
GENERAL_MAX_RETRIES=3
GENERAL_TIMEOUT=30000

# Target markets
TARGET_COUNTRIES=Dubai,Abu Dhabi,Riyadh,Jeddah,Doha,Kuwait City,USA,UK,Canada,Australia

# Target industries
TARGET_INDUSTRIES=Real Estate,B2B SaaS,Marketing Agencies,Financial Services,Healthcare Clinics,Logistics

# Target titles
TARGET_TITLES=Founder,CEO,Managing Director,Co-Founder,VP Sales,Head of Sales,Director of Sales,Director of Growth,COO,Director of Operations,CMO

# Output configuration
OUTPUT_DIRECTORY=./scraped_leads
